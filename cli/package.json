    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/shufflgl/aix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shufflgl/aix.git",
