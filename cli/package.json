{
  "name": "@shufflgl/aix",
  "version": "0.1.0",
  "description": "Agent-oriented AI Extensions Manager CLI for Codex and Claude ext assets",
  "type": "module",
  "bin": {
    "aix": "dist/index.js"
  },
