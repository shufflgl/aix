{
  "name": "aix-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "build": "npm --workspace cli run build",
    "typecheck": "npm --workspace cli run typecheck",
    "aix": "node cli/dist/index.js",
    "check": "npm run typecheck && npm run build",
    "pack:cli": "npm --workspace cli pack --dry-run"
  }
}
